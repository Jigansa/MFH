<%- include("background.ejs") %>

<style>
    .donation-container {
        max-width: 800px;
        margin: 40px auto;
        padding: 30px;
        background-color: #ffffff;
        border-radius: 10px;
        box-shadow: 0 4px 8px rgba(0, 0, 0, 0.1);
    }

    .donation-header {
        text-align: center;
        margin-bottom: 30px;
    }

    .donation-header h1 {
        color: #2f4507;
        font-size: 2.5rem;
        margin-bottom: 15px;
    }

    .donation-header p {
        color: #666;
        font-size: 1.1rem;
    }

    .donation-amounts {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 15px;
        margin-bottom: 30px;
    }

    .amount-button {
        padding: 15px;
        border: 2px solid #2f4507;
        border-radius: 8px;
        background: none;
        color: #2f4507;
        font-size: 1.2rem;
        cursor: pointer;
        transition: all 0.3s ease;
    }

    .amount-button:hover, .amount-button.selected {
        background-color: #2f4507;
        color: white;
    }

    .custom-amount {
        margin: 20px 0;
        text-align: center;
    }

    .custom-amount input {
        width: 200px;
        padding: 12px;
        border: 2px solid #2f4507;
        border-radius: 8px;
        font-size: 1.1rem;
        text-align: center;
    }

    .donate-button {
        display: block;
        width: 200px;
        margin: 30px auto;
        padding: 15px;
        background-color: #2f4507;
        color: white;
        border: none;
        border-radius: 8px;
        font-size: 1.2rem;
        cursor: pointer;
        transition: background-color 0.3s ease;
    }

    .donate-button:hover {
        background-color: #3d6709;
    }

    .donate-button:disabled {
        background-color: #ccc;
        cursor: not-allowed;
    }
</style>

<div class="donation-container">
    <div class="donation-header">
        <h1>Support Our Cause</h1>
        <p>Your contribution makes a difference in the lives of Himalayan communities</p>
    </div>

    <div class="donation-amounts">
        <button class="amount-button" data-amount="5">₹5</button>
        <button class="amount-button" data-amount="10">₹10</button>
        <button class="amount-button" data-amount="10000">₹10,000</button>
        <button class="amount-button" data-amount="50000">₹50,000</button>
        <button class="amount-button" data-amount="100000">₹1,00,000</button>
    </div>

    <div class="custom-amount">
        <input type="number" id="customAmount" placeholder="Custom Amount" min="1">
    </div>

    <button class="donate-button" id="donateButton" disabled>Donate Now</button>
</div>

<script src="https://checkout.razorpay.com/v1/checkout.js"></script>
<script>
    let selectedAmount = 0;
    const amountButtons = document.querySelectorAll('.amount-button');
    const customAmountInput = document.getElementById('customAmount');
    const donateButton = document.getElementById('donateButton');

    // Handle preset amount buttons
    amountButtons.forEach(button => {
        button.addEventListener('click', () => {
            amountButtons.forEach(btn => btn.classList.remove('selected'));
            button.classList.add('selected');
            selectedAmount = parseInt(button.dataset.amount);
            customAmountInput.value = '';
            donateButton.disabled = false;
        });
    });

    // Handle custom amount input
    customAmountInput.addEventListener('input', () => {
        amountButtons.forEach(btn => btn.classList.remove('selected'));
        selectedAmount = parseInt(customAmountInput.value) || 0;
        donateButton.disabled = selectedAmount <= 0;
    });

    // Handle donation
    donateButton.addEventListener('click', async () => {
        if (selectedAmount <= 0) return;

        try {
            const response = await fetch('/create-order', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify({ amount: selectedAmount })
            });
            
            const data = await response.json();
            if (!data.success) throw new Error('Failed to create order');

            const options = {
                key: '<%= process.env.RAZORPAY_KEY_ID %>',
                amount: data.order.amount,
                currency: data.order.currency,
                name: 'Mountain Forum Himalayas',
                description: 'Donation to MFH',
                order_id: data.order.id,
                handler: async function (response) {
                    try {
                        const result = await fetch('/payment-success', {
                            method: 'POST',
                            headers: {
                                'Content-Type': 'application/json',
                            },
                            body: JSON.stringify({
                                razorpay_payment_id: response.razorpay_payment_id,
                                razorpay_order_id: response.razorpay_order_id,
                                razorpay_signature: response.razorpay_signature,
                                amount: selectedAmount
                            })
                        });
                        
                        const resultData = await result.json();
                        if (resultData.success) {
                            alert('Thank you for your donation!');
                            window.location.reload();
                        } else {
                            alert('Payment verification failed. Please contact support.');
                        }
                    } catch (error) {
                        console.error('Error processing payment:', error);
                        alert('Error processing payment. Please contact support.');
                    }
                },
                prefill: {
                    name: '',
                    email: '',
                    contact: ''
                },
                theme: {
                    color: '#2f4507'
                }
            };

            const rzp = new Razorpay(options);
            rzp.open();
        } catch (error) {
            console.error('Error:', error);
            alert('Error initiating payment. Please try again.');
        }
    });
</script>

<%- include("footer.ejs") %>
